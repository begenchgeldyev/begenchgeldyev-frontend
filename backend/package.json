{
  "name": "personal-website-backend",
  "author": "Begench Geldyev <begenchgeldyev@gmail.com>",
  "version": "1.0.0",
  "description": "Personal website BFF server — Bun + HTMX fragments",
  "license": "MIT",
  "scripts": {
    "start": "bun server.ts",
    "dev": "bun --hot server.ts",
    "lint": "biome check .",
    "format": "biome check --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "devDependencies": {
    "@biomejs/biome": "latest",
    "@types/bun": "latest",
    "bun-types": "^1.3.12",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3"
  },
  "private": true,
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  }
}
