{
	"$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
	"formatter": {
		"enabled": true,
		"lineWidth": 140
	},
	"linter": {
		"enabled": true
	},
	"assist": {
		"enabled": true
	},
	"html": {
